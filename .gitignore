# Database dumps - NEVER commit these (contain sensitive user data)
*.sql
*.sql.gz

# Allow schema migration files in the database/ directory
!database/
!database/*.sql

# Configuration with credentials
app/config.php

# PHP error logs
*.log
error_log

# System files
.DS_Store
Thumbs.db

# Uploads directory (user-submitted files)
app/uploads/

# Environment files
.env
.env.*
*.env
env.*
.environment
nohup.out
